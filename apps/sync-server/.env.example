# --- Database (apps/sync-server) ---
# Prisma connection string (pooled)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/syncpad?schema=public"

# --- Sync server (apps/sync-server) ---
# Port to run the Hocuspocus WebSocket server on
PORT="1234"
# HMAC secret used to verify tokens signed by apps/web
SYNC_SERVER_INTERNAL_SECRET="your-internal-websocket-hmac-secret-key"

# --- Misc / Constants ---
NODE_ENV="development"
MAX_DOCUMENT_SIZE_BYTES="5000000" # 5MB encoded Yjs state size ceiling
MAX_WS_MESSAGE_BYTES="1000000"    # 1MB WebSocket frame ceiling
